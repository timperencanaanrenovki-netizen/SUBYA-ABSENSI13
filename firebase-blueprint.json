{
  "entities": {
    "employee": {
      "title": "Employee",
      "description": "Information about an employee registered in Diarsiteki Absensi.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string", "maxLength": 100 },
        "jabatan": { "type": "string", "maxLength": 100 },
        "posisi": { "type": "string", "enum": ["Kantor", "Lapangan"] },
        "photoUrl": { "type": "string" }
      },
      "required": ["id", "name", "jabatan", "posisi", "photoUrl"]
    },
    "attendancePair": {
      "title": "AttendancePair",
      "description": "A pair of clock-in (masuk) and clock-out (pulang) attendance details for a given employee and date.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "employeeId": { "type": "string" },
        "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "dateLabel": { "type": "string" },
        "status": { "type": "string", "enum": ["Hadir", "Telat", "Sakit", "Izin", "Cuti"] },
        "masuk": {
          "type": "object"
        },
        "pulang": {
          "type": "object"
        },
        "workDurationMinutes": { "type": "integer" },
        "notes": { "type": "string", "maxLength": 500 }
      },
      "required": ["id", "employeeId", "date", "dateLabel", "status"]
    }
  },
  "firestore": {
    "/employees/{employeeId}": {
      "schema": "employee",
      "description": "Collection of registered employees."
    },
    "/attendance/{attendanceId}": {
      "schema": "attendancePair",
      "description": "Collection of daily attendance records."
    }
  }
}
