rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    // Employee validation
    function isValidEmployee(data) {
      return data.keys().hasAll(['id', 'name', 'jabatan', 'posisi', 'photoUrl'])
        && data.keys().size() == 5
        && data.id is string
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.jabatan is string && data.jabatan.size() > 0 && data.jabatan.size() <= 100
        && data.posisi is string && (data.posisi == 'Kantor' || data.posisi == 'Lapangan')
        && data.photoUrl is string;
    }

    // Attendance validation
    function isValidAttendance(data) {
      return data.keys().hasAll(['id', 'employeeId', 'date', 'dateLabel', 'status'])
        && data.id is string
        && data.employeeId is string
        && data.date is string && data.date.matches('^\\d{4}-\\d{2}-\\d{2}$')
        && data.dateLabel is string && data.dateLabel.size() <= 100
        && data.status is string && (data.status == 'Hadir' || data.status == 'Telat' || data.status == 'Sakit' || data.status == 'Izin' || data.status == 'Cuti')
        && (!('masuk' in data) || data.masuk == null || (data.masuk is map && data.masuk.timestamp is string && data.masuk.photoUrl is string))
        && (!('pulang' in data) || data.pulang == null || (data.pulang is map && data.pulang.timestamp is string && data.pulang.photoUrl is string))
        && (!('workDurationMinutes' in data) || data.workDurationMinutes == null || data.workDurationMinutes is int)
        && (!('notes' in data) || data.notes == null || (data.notes is string && data.notes.size() <= 500));
    }

    match /employees/{employeeId} {
      allow read: if true;
      allow create: if isValidId(employeeId) && isValidEmployee(incoming()) && incoming().id == employeeId;
      allow update: if isValidId(employeeId) && isValidEmployee(incoming()) && incoming().id == employeeId;
      allow delete: if false;
    }

    match /attendance/{attendanceId} {
      allow read: if true;
      allow create: if isValidId(attendanceId) && isValidAttendance(incoming()) && incoming().id == attendanceId
        // Ensure employee exists
        && exists(/databases/$(database)/documents/employees/$(incoming().employeeId));
      allow update: if isValidId(attendanceId) && isValidAttendance(incoming()) && incoming().id == attendanceId;
      allow delete: if true;
    }
  }
}
